# === 实验 8-6 环境变量示例：复制为 .env 后填入你的 Key ===

# 选择服务商：openai（默认）| moonshot | ark
PROVIDER=openai

# OpenAI（默认使用）
OPENAI_API_KEY=your_openai_api_key_here

# 备选：Kimi / 火山方舟（把 PROVIDER 改成 moonshot 或 ark 时使用）
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# ARK_API_KEY=your_ark_api_key_here

# 被测 Agent 生成工具用的模型（默认 gpt-4o-mini）
AGENT_MODEL=gpt-4o-mini
# LLM-as-a-Judge 打分用的模型（默认 gpt-4o-mini，可换 gpt-4o 更严格）
JUDGE_MODEL=gpt-4o-mini
TEMPERATURE=0.2

# 注意：OPENROUTER / ANTHROPIC / DEEPSEEK / SILICONFLOW 的 Key 当前不可用，请勿使用。
